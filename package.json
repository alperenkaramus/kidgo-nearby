{
  "name": "kids-near-me",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Global kid-friendly nearby places decision engine MVP.",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "seo:generate": "node scripts/generate-seo.mjs",
    "seo:check": "npm run seo:generate && node scripts/verify-seo.mjs",
    "build": "npm run seo:generate && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "check": "npm test && npm run smoke && npm run smoke:geodata && npm run seo:check && npm run build",
    "smoke": "node scripts/smoke.mjs",
    "smoke:geodata": "node scripts/geodata-smoke.js",
    "test": "node --test tests/*.test.js"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^6.0.3",
    "lucide-react": "^1.25.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "vite": "^8.1.5"
  }
}
