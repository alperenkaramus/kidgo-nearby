{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "functions": {
    "api/google-places.mjs": {
      "maxDuration": 10
    },
    "api/osm-places.mjs": {
      "maxDuration": 15
    }
  },
  "redirects": [
    { "source": "/en", "destination": "/things-to-do-with-kids/", "permanent": true },
    { "source": "/tr", "destination": "/cocukla-gezilecek-yerler/", "permanent": true },
    { "source": "/ru", "destination": "/ru/kuda-poiti-s-detmi/", "permanent": true },
    { "source": "/de", "destination": "/de/aktivitaeten-mit-kindern/", "permanent": true }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ]
}
